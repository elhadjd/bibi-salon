# External site API (contacts & appointments)
# Base URL must include /api/site
SITE_API_BASE_URL=https://app.zyvoerp.com/api/site
SITE_API_KEY=your_site_api_key_here

# Booking deposit payments (checkout redirect)
# The API should accept POST and return a checkout URL field such as checkout_url or checkoutUrl
PAYMENT_API_BASE_URL=https://your-payment-provider.com/api
PAYMENT_API_KEY=your_payment_api_key_here
PAYMENT_API_CHECKOUT_PATH=/payments/checkout

# IMPORTANT — production hosting (bbsalonsuites.com):
# The .env file on your computer does NOT apply to the live site.
# Add SITE_API_BASE_URL, SITE_API_KEY, and payment variables in your hosting panel
# (Vercel → Settings → Environment Variables, or your server's .env).
